{
  "name": "tally-erp-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "docker:up:clean": "./scripts/docker/up.sh clean",
    "docker:up:schema": "./scripts/docker/up.sh schema",
    "docker:up:seeded": "./scripts/docker/up.sh seeded",
    "docker:down": "docker compose down --remove-orphans",
    "docker:logs": "docker compose logs -f postgres web"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
