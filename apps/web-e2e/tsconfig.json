{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["../web/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/db/*": ["../../packages/db/src/*"],
      "@workspace/db": ["../../packages/db/src/index.ts"]
    }
  },
  "include": ["e2e/**/*.ts"]
}
