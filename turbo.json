{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {},
    "db:migrate": {},
    "db:push": {},
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["CI", "PLAYWRIGHT_BASE_URL", "E2E_EMAIL", "E2E_PASSWORD"]
    }
  }
}
